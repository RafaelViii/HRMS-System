      </div>
      <p class="text-xs text-gray-500">Employees without an overtime authorization remain ineligible for OT pay until granted.</p>
    </form>
  </section>
</div>

<script>
(function(){
  const form = document.getElementById('compensationForm');
  if (!form) { return; }
  function addRow(type) {
    if (!type) { return; }
    const template = form.querySelector(`template[data-comp-template="${type}"]`);
    const list = form.querySelector(`[data-comp-list="${type}"]`);
    if (!template || !list) { return; }
    const clone = template.content.firstElementChild.cloneNode(true);
    list.appendChild(clone);
    const input = clone.querySelector('input');
    if (input) { input.focus(); }
  }
  form.querySelectorAll('[data-comp-add]').forEach((btn) => {
    btn.addEventListener('click', () => {
      addRow(btn.getAttribute('data-comp-add'));
    });
  });
  form.addEventListener('click', (event) => {
    const removeBtn = event.target.closest('[data-comp-remove]');
    if (!removeBtn) { return; }
    const row = removeBtn.closest('[data-comp-row]');
    if (!row) { return; }
    const list = row.parentElement;
    const type = list ? list.getAttribute('data-comp-list') : null;
    row.remove();
    if (type && !list.querySelector('[data-comp-row]')) {
      addRow(type);
    }
  });
})();
</script>
<script>
(function(){
  const selectAll = document.querySelector('[data-ot-select-all]');
  const container = document.querySelector('[data-ot-list] tbody');
  const enabledLabel = document.querySelector('[data-ot-enabled-count]');
  if (!selectAll || !container) { return; }
  const checkboxes = () => Array.from(container.querySelectorAll('input[data-ot-toggle]'));
  function updateSelectAllState() {
    const boxes = checkboxes();
    if (!boxes.length) { return; }
    const allChecked = boxes.every(cb => cb.checked);
    const anyChecked = boxes.some(cb => cb.checked);
    selectAll.indeterminate = !allChecked && anyChecked;
    selectAll.checked = allChecked;
  }
  function updateEnabledLabel() {
    if (!enabledLabel) { return; }
    const count = checkboxes().filter(cb => cb.checked).length;
    enabledLabel.textContent = count;
  }
  selectAll.addEventListener('change', () => {
    checkboxes().forEach(cb => { cb.checked = selectAll.checked; });
    updateSelectAllState();
    updateEnabledLabel();
  });
  container.addEventListener('change', (event) => {
    if (!event.target.matches('input[data-ot-toggle]')) { return; }
    updateSelectAllState();
    updateEnabledLabel();
  });
  updateSelectAllState();
  updateEnabledLabel();
})();
</script>
