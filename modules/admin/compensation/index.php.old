          </div>
          <div>
            <label class="text-xs uppercase tracking-wide text-gray-500">Notes</label>
            <textarea class="input-text w-full" name="comp_notes" rows="3" placeholder="Context for future changes."><?= htmlspecialchars($payrollNotes) ?></textarea>
          </div>
