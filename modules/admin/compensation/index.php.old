<?php
require_once __DIR__ . '/../../../includes/auth.php';
require_access('payroll', 'compensation_defaults', 'manage');
require_once __DIR__ . '/../../../includes/db.php';
require_once __DIR__ . '/../../../includes/utils.php';
require_once __DIR__ . '/../../../includes/payroll.php';

$pageTitle = 'Compensation Defaults';
$pdo = get_db_conn();
$currentUser = current_user();
$currentUserId = (int)($currentUser['id'] ?? 0);
action_log('payroll', 'view_compensation_admin');

$searchTerm = trim((string)($_GET['q'] ?? ''));
$redirectBase = BASE_URL . '/modules/admin/compensation';

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $redirectUrl = $redirectBase;
    if ($searchTerm !== '') {
        $redirectUrl .= '?q=' . urlencode($searchTerm);
    }

    if (!csrf_verify($_POST['csrf'] ?? '')) {
        flash_error('Invalid form token. Please try again.');
        header('Location: ' . $redirectUrl);
        exit;
    }

    $action = trim((string)($_POST['action'] ?? ''));

    try {
        switch ($action) {
            case 'save_compensation_defaults':
                $authz = ensure_action_authorized('payroll', 'compensation_defaults', 'admin');
                if (!$authz['ok']) {
                    $msg = $authz['error'] === 'no_access'
                        ? 'You do not have permission to update compensation defaults.'
                        : 'Authorization failed. Provide a valid admin credential.';
                    flash_error($msg);
                    break;
                }

                $parseBucket = static function (array $rawBucket, string $labelPrefix, array &$collector): array {
                    $labels = isset($rawBucket['label']) && is_array($rawBucket['label']) ? $rawBucket['label'] : [];
                    $codes = isset($rawBucket['code']) && is_array($rawBucket['code']) ? $rawBucket['code'] : [];
                    $amounts = isset($rawBucket['amount']) && is_array($rawBucket['amount']) ? $rawBucket['amount'] : [];
                    $max = max(count($labels), count($codes), count($amounts));
                    $items = [];
                    for ($i = 0; $i < $max; $i++) {
                        $label = trim((string)($labels[$i] ?? ''));
                        $code = trim((string)($codes[$i] ?? ''));
                        $amountRaw = trim((string)($amounts[$i] ?? ''));
                        if ($label === '' && $code === '' && $amountRaw === '') {
                            continue;
                        }
                        if ($label === '') {
                            $collector[] = $labelPrefix . ' row ' . ($i + 1) . ' needs a label.';
                            continue;
                        }
                        if ($amountRaw === '' || !is_numeric($amountRaw)) {
                            $collector[] = $labelPrefix . ' row ' . ($i + 1) . ' amount must be numeric.';
                            continue;
                        }
                        $items[] = [
                            'label' => $label,
                            'code' => $code,
                            'amount' => (float)$amountRaw,
                        ];
                    }
                    return $items;
                };

                $collector = [];
                $allowanceRows = is_array($_POST['allowances'] ?? null) ? $_POST['allowances'] : [];
                $deductionRows = is_array($_POST['deductions'] ?? null) ? $_POST['deductions'] : [];
                $allowances = $parseBucket($allowanceRows, 'Allowance', $collector);
                $deductions = $parseBucket($deductionRows, 'Contribution', $collector);

                $notesRaw = trim((string)($_POST['comp_notes'] ?? ''));
                $notes = $notesRaw !== '' ? $notesRaw : null;

                $taxPercentage = null;
                $taxRaw = trim((string)($_POST['tax_percentage'] ?? ''));
                if ($taxRaw !== '') {
                    if (!is_numeric($taxRaw)) {
                        $collector[] = 'Tax percentage must be numeric.';
                    } else {
                        $taxPercentage = max(0.0, min(100.0, (float)$taxRaw));
                    }
                }

                if ($collector) {
                    flash_error(implode(' ', array_unique($collector)));
                    break;
                }

                $actorId = (int)($authz['as_user'] ?? $currentUserId ?: null) ?: null;
                $saved = payroll_save_compensation_defaults($pdo, $allowances, $deductions, $notes, $actorId, $taxPercentage);
                if ($saved) {
                    $context = [
                        'allowances' => count($allowances),
                        'deductions' => count($deductions),
                        'tax_percentage' => $taxPercentage,
                        'authorized_by' => $actorId,
                    ];
                    action_log('payroll', 'compensation_defaults_saved', 'success', $context);
                    audit('payroll_comp_defaults_saved', json_encode($context, JSON_UNESCAPED_SLASHES));
                    flash_success('Payroll compensation defaults updated.');
                } else {
                    flash_error('Unable to save compensation defaults.');
                }
                break;

            case 'save_overtime_authorizations':
                $authz = ensure_action_authorized('payroll', 'overtime_authorizations', 'write');
                if (!$authz['ok']) {
                    $msg = $authz['error'] === 'no_access'
                        ? 'You do not have permission to change overtime authorizations.'
                        : 'Authorization failed. Provide a valid credential.';
                    flash_error($msg);
                    break;
                }

                $idsRaw = $_POST['employee_ids'] ?? [];
                if (!is_array($idsRaw) || !$idsRaw) {
                    flash_error('Select at least one employee to update.');
                    break;
                }
                $employeeIds = [];
                foreach ($idsRaw as $id) {
                    $empId = (int)$id;
                    if ($empId > 0) {
                        $employeeIds[$empId] = true;
                    }
                }
                $employeeIds = array_keys($employeeIds);
                if (!$employeeIds) {
                    flash_error('Select at least one employee to update.');
                    break;
                }

                $allowOtInput = $_POST['allow_ot'] ?? [];
                $allowedMap = [];
                if (is_array($allowOtInput)) {
                    foreach ($allowOtInput as $empId => $flag) {
                        $allowedMap[(int)$empId] = true;
                    }
                }

                $placeholders = implode(',', array_fill(0, count($employeeIds), '?'));
                $lookupSql = 'SELECT id, employee_code, first_name, last_name FROM employees WHERE id IN (' . $placeholders . ')';
                $stmtLookup = $pdo->prepare($lookupSql);
                foreach ($employeeIds as $idx => $empId) {
                    $stmtLookup->bindValue($idx + 1, $empId, PDO::PARAM_INT);
                }
                $stmtLookup->execute();
                $existing = $stmtLookup->fetchAll(PDO::FETCH_ASSOC) ?: [];
                if (!$existing) {
                    flash_error('The selected employees were not found.');
                    break;
                }

                $existingIndex = [];
                foreach ($existing as $row) {
                    $existingIndex[(int)$row['id']] = $row;
                }

                $actorId = (int)($authz['as_user'] ?? $currentUserId ?: null) ?: null;
                $updated = 0;
                $enabled = 0;
                $disabled = 0;
                $failures = [];

                foreach ($employeeIds as $empId) {
                    if (!isset($existingIndex[$empId])) {
                        continue;
                    }
                    $allow = !empty($allowedMap[$empId]);
                    $result = payroll_save_employee_profile($pdo, $empId, ['allow_overtime' => $allow], $actorId);
                    if ($result) {
                        $updated++;
                        if ($allow) {
                            $enabled++;
                        } else {
                            $disabled++;
                        }
                    } else {
                        $failures[] = $existingIndex[$empId]['employee_code'] ?? (string)$empId;
                    }
                }

                if ($failures) {
                    sys_log('PAYROLL-OT-AUTH', 'Failed updating overtime authorization for some employees', [
                        'module' => 'payroll',
                        'file' => __FILE__,
                        'line' => __LINE__,
                        'context' => ['failures' => $failures],
                    ]);
                    flash_error('Unable to update overtime for: ' . implode(', ', array_slice($failures, 0, 5)) . '.');
                    break;
                }

                if ($updated === 0) {
                    flash_error('No overtime authorizations were changed.');
                    break;
                }

                $context = [
                    'updated' => $updated,
                    'enabled' => $enabled,
                    'disabled' => $disabled,
                    'authorized_by' => $actorId,
                ];
                action_log('payroll', 'overtime_authorization_updated', 'success', $context);
                audit('payroll_overtime_authorization_updated', json_encode($context, JSON_UNESCAPED_SLASHES));
                flash_success('Overtime authorization updated for ' . $updated . ' employee' . ($updated === 1 ? '' : 's') . '.');
                break;

            default:
                flash_error('Unsupported action.');
                break;
        }
    } catch (Throwable $e) {
        sys_log('ADMIN-COMPENSATION-POST', 'Failed processing compensation admin action: ' . $e->getMessage(), [
            'module' => 'admin',
            'file' => __FILE__,
            'line' => __LINE__,
            'context' => ['action' => $action],
        ]);
        flash_error('We could not process the requested change.');
    }

    header('Location: ' . $redirectUrl);
    exit;
}

$payrollDefaults = payroll_get_compensation_defaults($pdo);
$payrollAllowances = $payrollDefaults['allowances'] ?? [];
$payrollDeductions = $payrollDefaults['deductions'] ?? [];
$payrollNotes = (string)($payrollDefaults['notes'] ?? '');
$payrollTax = isset($payrollDefaults['tax_percentage']) && $payrollDefaults['tax_percentage'] !== null
    ? (float)$payrollDefaults['tax_percentage']
    : null;
$payrollUpdatedAt = $payrollDefaults['updated_at'] ?? null;
$payrollUpdatedBy = $payrollDefaults['updated_by'] ?? null;

$payrollUpdatedByLabel = null;
if ($payrollUpdatedBy) {
    try {
        $stmtUser = $pdo->prepare('SELECT full_name, email FROM users WHERE id = :id');
        $stmtUser->execute([':id' => $payrollUpdatedBy]);
        $userRow = $stmtUser->fetch(PDO::FETCH_ASSOC) ?: null;
        if ($userRow) {
            $name = trim((string)($userRow['full_name'] ?? ''));
            $payrollUpdatedByLabel = $name !== '' ? $name : strtolower((string)($userRow['email'] ?? ''));
        }
    } catch (Throwable $e) {
        sys_log('PAYROLL-COMP-UPDATER', 'Failed resolving payroll defaults updater: ' . $e->getMessage(), [
            'module' => 'payroll',
            'file' => __FILE__,
            'line' => __LINE__,
        ]);
    }
}

$payrollUpdatedAtLabel = null;
if ($payrollUpdatedAt) {
  $formatted = format_datetime_display($payrollUpdatedAt, true, '—');
  $payrollUpdatedAtLabel = $formatted !== '—' ? $formatted : null;
}

$formatAmount = static function ($value): string {
    if ($value === null || $value === '') {
        return '';
    }
    $formatted = number_format((float)$value, 2, '.', '');
    return rtrim(rtrim($formatted, '0'), '.');
};

$allowanceRows = $payrollAllowances ?: [['code' => '', 'label' => '', 'amount' => '']];
$deductionRows = $payrollDeductions ?: [['code' => '', 'label' => '', 'amount' => '']];

try {
    payroll_ensure_employee_profiles_table($pdo);
} catch (Throwable $e) {
    sys_log('PAYROLL-PROFILE-TABLE', 'Failed ensuring employee payroll profiles table: ' . $e->getMessage(), [
        'module' => 'payroll',
        'file' => __FILE__,
        'line' => __LINE__,
    ]);
}

$employeeRows = [];
$employeeParams = [];
$employeeSql = "SELECT e.id, e.employee_code, e.first_name, e.last_name, e.email, e.status, 
       b.name AS branch_name, 
       COALESCE(pp.allow_overtime, FALSE) AS allow_overtime,
       pp.updated_at AS ot_updated_at,
       u.full_name AS updated_by_name,
       u.email AS updated_by_email
FROM employees e
LEFT JOIN branches b ON b.id = e.branch_id
LEFT JOIN employee_payroll_profiles pp ON pp.employee_id = e.id
LEFT JOIN users u ON u.id = pp.updated_by
WHERE e.status NOT IN ('resigned', 'terminated')";
if ($searchTerm !== '') {
    $employeeSql .= " AND (e.first_name ILIKE :term OR e.last_name ILIKE :term OR e.email ILIKE :term OR e.employee_code ILIKE :term)";
    $employeeParams[':term'] = '%' . $searchTerm . '%';
}
$employeeSql .= ' ORDER BY e.first_name ASC, e.last_name ASC, e.id ASC';
try {
    $stmtEmp = $pdo->prepare($employeeSql);
    foreach ($employeeParams as $key => $val) {
        $stmtEmp->bindValue($key, $val, PDO::PARAM_STR);
    }
    $stmtEmp->execute();
    $employeeRows = $stmtEmp->fetchAll(PDO::FETCH_ASSOC) ?: [];
} catch (Throwable $e) {
    sys_log('PAYROLL-OT-LIST', 'Failed loading employee overtime list: ' . $e->getMessage(), [
        'module' => 'payroll',
        'file' => __FILE__,
        'line' => __LINE__,
    ]);
    $employeeRows = [];
}

$otStats = ['total' => count($employeeRows), 'allowed' => 0, 'last_update' => null];
foreach ($employeeRows as $row) {
    if (!empty($row['allow_overtime'])) {
        $otStats['allowed']++;
    }
    if (!empty($row['ot_updated_at'])) {
        $ts = strtotime((string)$row['ot_updated_at']);
        if ($ts && ($otStats['last_update'] === null || $ts > $otStats['last_update'])) {
            $otStats['last_update'] = $ts;
        }
    }
}
$otStats['last_update_label'] = null;
if ($otStats['last_update']) {
  $formattedLast = format_datetime_display(date('Y-m-d H:i:s', $otStats['last_update']), true, '—');
  $otStats['last_update_label'] = $formattedLast !== '—' ? $formattedLast : null;
}

$csrf = csrf_token();

require_once __DIR__ . '/../../../includes/header.php';
?>

