# Deny direct access to PHP and other executable files in the uploads directory
# This prevents uploaded PHP files from being executed by the web server

# Disable PHP engine entirely for this directory
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# Block access to PHP-related executable files
<FilesMatch "\.(php|phtml|phar|php[0-9]|shtml|cgi|pl|py|rb|sh|bash)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Remove handlers for executable types
<IfModule mod_mime.c>
    RemoveHandler .php .phtml .phar .php3 .php4 .php5 .php7 .php8
    RemoveType .php .phtml .phar .php3 .php4 .php5 .php7 .php8
</IfModule>

# Prevent directory listing
Options -Indexes -ExecCGI
