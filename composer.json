{
  "name": "bobsi01/hrms-sysfunda",
  "description": "HRMS - PHP app for Heroku with PostgreSQL",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5.62"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.3.0"
    }
  }
}
